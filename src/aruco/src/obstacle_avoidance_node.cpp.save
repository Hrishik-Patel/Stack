      if (cz < min_dist || cz > max_dist)  continue;
      if (std::abs(cx) > half_w)           continue;
      if (cy > max_cy || cy < min_cy)      continue;

      if (cz < best_d) {
        best_d = cz;
        bx = cz;   // obs_x_ = depth to obstacle
        by = cx;   // obs_y_ = lateral position of obstacle (+right / -left)
